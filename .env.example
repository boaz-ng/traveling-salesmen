# LLM provider toggle: "qwen" (default) or "anthropic"
LLM_PROVIDER=qwen
# Optional model override (leave empty for provider default)
# LLM_MODEL=

# Qwen API credentials (sign up at https://dashscope.console.aliyun.com/)
QWEN_API_KEY=your-qwen-api-key-here
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Anthropic (Claude) API key — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Amadeus API credentials (sign up at https://developers.amadeus.com)
AMADEUS_API_KEY=your-amadeus-api-key-here
AMADEUS_API_SECRET=your-amadeus-api-secret-here
AMADEUS_ENV=test
